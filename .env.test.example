# ─── Belori Test Environment ──────────────────────────────────────────────
# Copy this file to `.env.test` and fill in the values.
# DO NOT commit `.env.test` — it's in .gitignore.
#
# See docs/TESTING_SUPABASE_SETUP.md for full provisioning instructions.
#
# CRITICAL: `.env.test` must NEVER point at the production Supabase project.
# `scripts/verify-test-env.mjs` will refuse to run tests if it detects the
# production project ref `bohdabdgqgfeatpxyvbz`.

# ─── Supabase (test project) ──────────────────────────────────────────────
# Get these from your test project's Settings → API:
#   https://supabase.com/dashboard/project/<YOUR_TEST_REF>/settings/api
#
# DO NOT use the production project's URL or keys here.
VITE_SUPABASE_URL=https://YOUR_TEST_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_TEST_ANON_KEY

# Mirror of above — the verify script cross-checks these match.
TEST_SUPABASE_URL=https://YOUR_TEST_PROJECT_REF.supabase.co
TEST_SUPABASE_ANON_KEY=YOUR_TEST_ANON_KEY

# Service-role key — only used by Playwright global-setup to seed test users
# and verify RLS. Never imported by frontend code.
# Store in your vault; paste here locally; never commit.
TEST_SUPABASE_SERVICE_ROLE_KEY=YOUR_TEST_SERVICE_ROLE_KEY

# ─── App URL (Vite) ────────────────────────────────────────────────────────
# Playwright's webServer will boot Vite on this URL.
VITE_APP_URL=http://localhost:5173

# ─── Test user credentials (created by supabase/seed.test.sql) ────────────
# Seed script provisions these four users in the test project.
# Playwright storageState fixtures sign in as each.
TEST_OWNER_A_EMAIL=owner-a@belori-test.local
TEST_OWNER_A_PASSWORD=TestPassword123!
TEST_STAFF_A_EMAIL=coordinator-a@belori-test.local
TEST_STAFF_A_PASSWORD=TestPassword123!
TEST_OWNER_B_EMAIL=owner-b@belori-test.local
TEST_OWNER_B_PASSWORD=TestPassword123!
TEST_STAFF_B_EMAIL=seamstress-b@belori-test.local
TEST_STAFF_B_PASSWORD=TestPassword123!

# ─── Test Twilio (optional — only needed for SMS-path E2E) ────────────────
# Use Twilio magic numbers so no real SMS is ever sent.
#   +15005550006 — always succeeds
#   +15005550001 — always fails (invalid)
#   +15005550008 — always blocked
# https://www.twilio.com/docs/iam/test-credentials
TEST_TWILIO_ACCOUNT_SID=
TEST_TWILIO_AUTH_TOKEN=
TEST_TWILIO_FROM_NUMBER=+15005550006

# ─── Test Stripe (optional — only needed for billing E2E) ─────────────────
# Stripe test mode. NOT live mode.
TEST_STRIPE_PUBLISHABLE_KEY=pk_test_
TEST_STRIPE_SECRET_KEY=sk_test_
TEST_STRIPE_WEBHOOK_SECRET=whsec_

# ─── Test Resend (optional — only needed for email-path E2E) ─────────────
# Use a sandbox domain or the generic @resend.dev address.
TEST_RESEND_API_KEY=re_
TEST_RESEND_FROM_EMAIL=Belori Test <onboarding@resend.dev>

# ─── Flags ─────────────────────────────────────────────────────────────────
NODE_ENV=test
# Set to "1" to allow the verify script to skip the live-ping check
# (useful for CI where the test project may briefly be unreachable).
SKIP_SUPABASE_PING=0
