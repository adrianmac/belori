{
  "name": "belori",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "setup:test-supabase": "node scripts/setup-test-supabase.mjs",
    "verify:test-env": "node scripts/verify-test-env.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run verify:test-env && playwright test",
    "test:e2e:ui": "npm run verify:test-env && playwright test --ui",
    "test:e2e:debug": "npm run verify:test-env && playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:seed:users": "node scripts/seed-test-users.mjs",
    "test:seed": "supabase db execute --file supabase/seed.test.sql",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/react": "^10.49.0",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "inngest": "^4.1.0",
    "jspdf": "^4.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.5.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/ui": "^2.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "supabase": "^2.93.0",
    "vite": "^8.0.0",
    "vitest": "^2.1.9"
  }
}
